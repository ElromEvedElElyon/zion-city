    },
    {
      "name": "wallet_check",
      "description": "Check all wallet balances",
      "steps": [
        {"tool": "bash_safe", "args": {"cmd": "echo 'EVM: 0x6b45b26e1d59A832FE8c9E7c685C36Ea54A3F88B'"}},
        {"tool": "bash_safe", "args": {"cmd": "echo 'SOL: CM42ofAFowySg72GjDuCchEkwwbwnhdSRYgztRCAAEzR'"}},
